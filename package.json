{
  "name": "skaut-handbook-web-admin",
  "version": "3.0.6",
  "description": "A web administration interface for a Scout handbook",
  "keywords": [
    "education",
    "handbook",
    "odymaterialy",
    "scout",
    "skaut"
  ],
  "homepage": "https://github.com/scout-handbook/handbook-web-admin",
  "bugs": {
    "url": "https://github.com/scout-handbook/handbook-web-admin/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/scout-handbook/handbook-web-admin.git"
  },
  "license": "MIT",
  "author": "Marek Dědič",
  "type": "module",
  "exports": {
    ".": null
  },
  "sideEffects": true,
  "files": [
    "dist"
  ],
  "scripts": {
    "prebuild": "npm run clean",
    "build": "vite build",
    "clean": "rimraf dist/*",
    "lint": "run-p -c --aggregate-output lint:*",
    "lint:css": "run-p -c --aggregate-output lint:css:*",
    "lint:css:stylelint": "stylelint --color 'src/**/*.css' 'static/**/*.css' '!src/lib/font/fontello.css'",
    "lint:eslint": "eslint --color",
    "lint:svelte": "run-p -c --aggregate-output lint:svelte:*",
    "lint:svelte:svelte-check": "FORCE_COLOR=1 svelte-check",
    "lint:ts": "run-p -c --aggregate-output lint:ts:*",
    "lint:ts:typecheck": "tsc --noEmit",
    "prepare": "svelte-kit sync"
  },
  "browserslist": [
    "defaults",
    "not OperaMini all"
  ],
  "dependencies": {
    "easymde": "^2.21.0",
    "showdown": "^2.1.0",
    "xss": "^1.0.15"
  },
  "devDependencies": {
    "@csstools/postcss-global-data": "^4.0.0",
    "@eslint-community/eslint-plugin-eslint-comments": "^4.7.2",
    "@eslint/css": "^1.3.0",
    "@eslint/js": "^10.0.1",
    "@eslint/json": "^2.0.0",
    "@eslint/markdown": "^8.0.2",
    "@fontsource/open-sans": "^5.2.7",
    "@sveltejs/adapter-static": "^3.0.10",
    "@sveltejs/kit": "^2.61.1",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tanstack/eslint-plugin-query": "^5.100.14",
    "@tanstack/svelte-query": "^6.1.33",
    "@types/codemirror": "5.60.17",
    "@types/node": "^25.9.1",
    "@types/showdown": "^2.0.6",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-compat": "^7.0.2",
    "eslint-plugin-package-json": "^1.2.0",
    "eslint-plugin-perfectionist": "^5.9.0",
    "eslint-plugin-prefer-arrow-functions": "^3.9.1",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-svelte": "^3.18.0",
    "globals": "^17.6.0",
    "npm-run-all": "^4.1.5",
    "postcss-custom-properties": "^15.0.0",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^4.0.1",
    "rimraf": "^6.1.3",
    "rollup-plugin-htaccess": "^0.13.2",
    "stylelint": "^17.12.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-no-unsupported-browser-features": "^8.1.1",
    "stylelint-prettier": "^5.0.3",
    "svelte": "^5.55.10",
    "svelte-check": "^4.4.8",
    "svelte-eslint-parser": "^1.6.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0",
    "vite": "^8.0.14"
  }
}
